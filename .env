# Expo Environment Variables
# Use EXPO_PUBLIC_ prefix for variables to be accessible in the app code

# Local Development (Laravel Sail)
# Note: If testing on a physical device via tunnel, use your machine's local IP (e.g., 192.168.1.xx) 
# or a service like ngrok to expose your local Sail instance.
# For Android Emulator, use http://10.0.2.2:8000
EXPO_PUBLIC_API_URL=http://localhost/api/v1
EXPO_PUBLIC_APP_ENV=local
